# ----- Required --------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
OVERSEERR_URL=http://overseerr:5055
OVERSEERR_API_KEY=
OWNER_TELEGRAM_USER_ID=

LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=

# ----- Optional (with defaults) ----------------------------------------------
# LLM_THINKING_LEVEL=off        # off | minimal | low | medium | high | xhigh
# LOG_LEVEL=info                # debug | info | warn | error
# DB_PATH=/data/homebot.db      # SQLite file location
# DAILY_COST_CAP_USD=1.00       # Refuse new LLM calls after this (UTC day)
# MAX_TURNS_IN_HISTORY=15       # Per-user conversation-turn cap
